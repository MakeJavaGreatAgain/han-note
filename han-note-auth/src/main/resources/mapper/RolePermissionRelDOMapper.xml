<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.hanserwei.hannote.auth.domain.mapper.RolePermissionRelDOMapper">

    <select id="selectByRoleIds" resultType="com.hanserwei.hannote.auth.domain.dataobject.RolePermissionRelDO">
        select role_id,permission_id
        from t_role_permission_rel
        where role_id in
        <foreach item="roleId" collection="roleIds" separator="," open="(" close=")">
            #{roleId}
        </foreach>;
    </select>
</mapper>