<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.hanserwei.hannote.user.biz.domain.mapper.RoleDOMapper">

    <select id="selectEnabledList" resultType="com.hanserwei.hannote.user.biz.domain.dataobject.RoleDO">
        select id, role_name, role_key
        from t_role
        where deleted = false
          and status = 0
    </select>

    <select id="selectByPrimaryKey" resultType="com.hanserwei.hannote.user.biz.domain.dataobject.RoleDO">
        select id, role_name, role_key
        from t_role
        where id = #{roleId}
          and deleted = false
          and status = 0
    </select>

    <select id="selectRoleKeyListByIdList" resultType="java.lang.String">
        select role_key
        from t_role
        where id in
        <foreach item="id" collection="list" open="(" separator="," close=")">
            #{id}
        </foreach>
        and deleted = false
        and status = 0
    </select>
</mapper>
